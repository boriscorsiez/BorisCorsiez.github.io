
<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>BullX - Darts Party</title>
    <style>
        /* === VARIABLES DE THÈME === */
        :root {
            --bg-color: #070b14; --card-bg: #111827; --card-bg-hover: #1f2937;
            --accent-green: #10b981; --accent-blue: #3b82f6; --accent-gold: #fbbf24;
            --text-main: #f8fafc; --text-muted: #64748b; --border-color: #334155; --danger-red: #ef4444;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', system-ui, sans-serif; -webkit-tap-highlight-color: transparent; }
        body { background-color: var(--bg-color); color: var(--text-main); display: flex; justify-content: center; height: 100vh; overflow: hidden; }
        
        #app-container {
            width: 100%; max-width: 430px; height: 100%; position: relative;
            background: radial-gradient(circle at top, #111827, #070b14);
            display: flex; flex-direction: column; overflow-y: auto; overflow-x: hidden;
        }

        .view {
            position: absolute; top: 0; left: 0; width: 100%; min-height: 100%;
            padding: 15px; display: none; flex-direction: column;
            animation: fadeIn 0.4s cubic-bezier(0.2, 0.8, 0.2, 1);
        }
        .view.active { display: flex; }
        @keyframes fadeIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } }

        /* === VUE 1 : SETUP === */
        .setup-title { font-size: 36px; text-align: center; margin: 20px 0; background: linear-gradient(90deg, #10b981, #fbbf24); -webkit-background-clip: text; color: transparent; font-weight: 900; letter-spacing: 2px;}
        .section-card { background: rgba(17, 24, 39, 0.8); border: 1px solid var(--border-color); border-radius: 20px; padding: 20px; margin-bottom: 20px; }
        .player-item { display: flex; align-items: center; background: #0f172a; border-radius: 12px; padding: 12px; margin-bottom: 8px; border: 1px solid var(--border-color); }
        .player-item input { flex: 1; background: transparent; border: none; color: white; font-size: 16px; outline: none; font-weight: bold; }
        .btn-icon { background: transparent; border: none; color: var(--text-muted); font-size: 20px; cursor: pointer; }
        .btn-add-player { width: 100%; padding: 12px; background: transparent; border: 2px dashed var(--accent-blue); color: var(--accent-blue); border-radius: 12px; font-weight: bold; margin-top: 5px; }
        
        .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; margin-top: 10px;}
        .toggle-btn { background: #0f172a; border: 1px solid var(--border-color); color: white; padding: 15px 5px; border-radius: 12px; font-weight: bold; font-size: 16px; transition: 0.3s; }
        .toggle-btn.selected { background: var(--accent-green); color: black; box-shadow: 0 0 15px rgba(16,185,129,0.5); border-color: var(--accent-green); }

        .btn-play { background: linear-gradient(135deg, #10b981, #059669); color: black; border: none; width: 100%; padding: 20px; border-radius: 15px; font-size: 20px; font-weight: 900; margin-top: auto; box-shadow: 0 10px 25px rgba(16,185,129,0.4); text-transform: uppercase; letter-spacing: 1px;}

        /* === VUE 2 : JEU === */
        .top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: 10px; }
        .btn-sound { font-size: 24px; background: none; border: none; cursor: pointer; filter: grayscale(100%); transition: 0.3s;}
        .btn-sound.on { filter: grayscale(0%); text-shadow: 0 0 10px #fbbf24;}

        .mini-dashboard { display: flex; gap: 8px; overflow-x: auto; padding-bottom: 10px; margin-bottom: 10px; scrollbar-width: none; }
        .dash-card { background: var(--card-bg); border: 1px solid var(--border-color); padding: 8px 12px; border-radius: 12px; min-width: 80px; text-align: center; opacity: 0.6; }
        .dash-card.active { border-color: var(--accent-blue); opacity: 1; background: rgba(59, 130, 246, 0.1); }
        .dash-name { font-size: 11px; color: var(--text-muted); text-transform: uppercase; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; font-weight: bold;}
        .dash-score { font-size: 20px; font-weight: bold; color: white; }

        .main-score-display { text-align: center; margin: 5px 0 15px 0; }
        .active-player-name { font-size: 22px; color: var(--accent-green); font-weight: 900; letter-spacing: 2px; text-transform: uppercase; }
        .huge-score { font-size: 95px; font-weight: 900; line-height: 1; margin: 0; background: linear-gradient(180deg, #ffffff, #94a3b8); -webkit-background-clip: text; color: transparent; text-shadow: 0 10px 30px rgba(0,0,0,0.5);}

        .darts-tray { display: flex; justify-content: center; gap: 10px; margin-bottom: 15px; align-items: center; background: rgba(0,0,0,0.4); padding: 10px; border-radius: 20px; }
        .dart-slot { width: 45px; height: 45px; border-radius: 50%; background: #0f172a; border: 2px solid var(--border-color); display: flex; justify-content: center; align-items: center; font-weight: bold; font-size: 16px; color: var(--text-muted); transition: 0.3s; }
        .dart-slot.filled { border-color: var(--accent-green); color: white; background: rgba(16, 185, 129, 0.2); box-shadow: 0 0 10px rgba(16,185,129,0.5); transform: scale(1.1); }
        .turn-sum { font-size: 30px; font-weight: 900; color: var(--accent-gold); width: 50px; text-align: right; }

        /* Clavier */
        .keyboard { display: flex; flex-direction: column; gap: 8px; margin-top: auto; padding-bottom: 10px; }
        .mult-row { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
        .mult-btn { background: #1e293b; border: 2px solid var(--border-color); color: white; padding: 15px; border-radius: 12px; font-weight: 900; font-size: 16px; text-transform: uppercase; transition: 0.2s; }
        .mult-btn[data-val="1"].active { background: #334155; border-color: #94a3b8; }
        .mult-btn[data-val="2"].active { background: #7f1d1d; border-color: var(--danger-red); box-shadow: 0 0 15px rgba(239, 68, 68, 0.5); }
        .mult-btn[data-val="3"].active { background: #064e3b; border-color: var(--accent-green); box-shadow: 0 0 15px rgba(16, 185, 129, 0.5); }

        .numpad { display: grid; grid-template-columns: repeat(5, 1fr); gap: 6px; margin-top: 5px; }
        .num-btn { background: #1e293b; border: 1px solid var(--border-color); color: white; padding: 12px 0; border-radius: 10px; font-size: 20px; font-weight: bold; transition: 0.1s;}
        .num-btn:active { background: #334155; transform: scale(0.95); }

        .special-actions { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px; margin-top: 5px; }
        .btn-bottom { border: none; border-radius: 10px; font-weight: bold; font-size: 15px; padding: 15px 0; text-transform: uppercase; color: white; box-shadow: 0 4px 6px rgba(0,0,0,0.3);}
        .btn-miss { background: #334155; }
        .btn-bull-outer { background: #059669; } 
        .btn-bull-inner { background: #dc2626; } 

        /* NOUVELLE ZONE ACTIONS BASSES (Valider + Retour) */
        .bottom-actions { display: flex; gap: 10px; margin-top: 5px; }
        
        .btn-undo { 
            background: #1e293b; border: 2px solid var(--border-color); color: var(--text-main); 
            border-radius: 12px; width: 75px; display: flex; justify-content: center; align-items: center; 
            cursor: pointer; transition: 0.2s; box-shadow: 0 4px 6px rgba(0,0,0,0.3);
        }
        .btn-undo:active { background: #334155; transform: scale(0.95); }
        .btn-undo:disabled { opacity: 0.3; cursor: not-allowed; }

        .btn-validate { 
            flex: 1; padding: 18px; border-radius: 12px; font-size: 18px; font-weight: 900; 
            background: linear-gradient(90deg, var(--accent-blue), #2563eb); box-shadow: 0 0 20px rgba(59,130,246,0.4); 
            color: white; border: none; text-transform: uppercase; cursor: pointer; transition: 0.2s;
        }
        .btn-validate:disabled { background: #1e293b; color: var(--text-muted); box-shadow: none; opacity: 0.5; }

        /* === OVERLAYS (ANIMATIONS PARTY) === */
        #party-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%; z-index: 1000;
            display: flex; flex-direction: column; justify-content: center; align-items: center;
            opacity: 0; pointer-events: none; transition: 0.3s;
        }
        #party-overlay.show { opacity: 1; pointer-events: all; }
        
        .party-text { font-size: 50px; font-weight: 900; text-transform: uppercase; text-align: center; padding: 0 20px; text-shadow: 2px 2px 0 #000; margin-bottom: 20px; transform: scale(0.5); transition: 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);}
        #party-overlay.show .party-text { transform: scale(1); }
        .party-points { font-size: 130px; font-weight: 900; line-height: 1; text-shadow: 0 0 40px currentColor; }

        .theme-trash { background: rgba(50,0,0,0.95); color: #ef4444; } 
        .theme-low { background: rgba(30,30,30,0.95); color: #94a3b8; } 
        .theme-mid { background: rgba(0,40,20,0.95); color: #34d399; } 
        .theme-high { background: rgba(40,0,60,0.95); color: #c084fc; text-shadow: 0 0 30px #c084fc;} 
        .theme-god { background: rgba(0,0,0,0.95); color: #fbbf24; animation: shake 0.5s infinite; text-shadow: 0 0 50px #ea580c;} 
        .theme-bust { background: rgba(255,0,0,0.9); color: white; animation: shake 0.2s infinite; } 

        @keyframes shake {
            0% { transform: translate(2px, 1px) rotate(0deg); }
            20% { transform: translate(-3px, 0px) rotate(1deg); }
            40% { transform: translate(1px, -1px) rotate(1deg); }
            60% { transform: translate(-3px, 1px) rotate(0deg); }
            80% { transform: translate(-1px, -1px) rotate(1deg); }
            100% { transform: translate(1px, -2px) rotate(-1deg); }
        }

        /* === ÉCRAN DE VICTOIRE === */
        #victory-screen {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.95); z-index: 2000; display: none;
            flex-direction: column; justify-content: center; align-items: center;
            background-image: radial-gradient(circle, #2563eb 0%, #000 70%);
        }
        #victory-screen.show { display: flex; animation: fadeIn 0.5s; }
        .crown { font-size: 80px; margin-bottom: -20px; animation: bounce 2s infinite; }
        .win-title { font-size: 30px; color: white; font-weight: bold; letter-spacing: 5px; }
        .win-name { font-size: 60px; color: var(--accent-gold); font-weight: 900; text-transform: uppercase; text-shadow: 0 0 30px #fbbf24; text-align: center; margin: 20px 0; }
        .btn-restart { background: var(--accent-green); border: none; padding: 20px 40px; font-size: 24px; font-weight: bold; border-radius: 50px; margin-top: 30px; cursor: pointer; box-shadow: 0 0 20px var(--accent-green); }

        @keyframes bounce { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(-20px); } }

    </style>
</head>
<body>

<div id="app-container">

    <!-- SETUP VIEW -->
    <div id="setup-view" class="view active">
        <h1 class="setup-title">🎯 BullX</h1>

        <div class="section-card">
            <h2 style="font-size: 14px; color: var(--text-muted); margin-bottom: 10px;">JOUEURS</h2>
            <div id="player-list"></div>
            <button class="btn-add-player" onclick="addPlayer()">+ Ajouter un pote</button>
        </div>

        <div class="section-card">
            <h2 style="font-size: 14px; color: var(--text-muted); margin-bottom: 10px;">FORMAT DU MATCH</h2>
            <div class="grid-4">
                <button class="toggle-btn score-btn" onclick="setScore(301)">301</button>
                <button class="toggle-btn score-btn selected" onclick="setScore(501)">501</button>
                <button class="toggle-btn score-btn" onclick="setScore(701)">701</button>
                <button class="toggle-btn score-btn" onclick="setScore(1001)">1001</button>
            </div>
        </div>

        <button class="btn-play" onclick="startGame()">C'EST PARTI ! ➔</button>
    </div>

    <!-- GAME VIEW -->
    <div id="game-view" class="view">
        <div class="top-bar">
            <button class="btn-icon" onclick="goBack()" style="font-size: 24px;">🔙</button>
            <button class="btn-sound" id="btn-audio" onclick="toggleAudio()">🔇</button>
        </div>

        <div class="mini-dashboard" id="mini-dashboard"></div>

        <div class="main-score-display">
            <div class="active-player-name" id="main-player-name">JOUEUR 1</div>
            <div class="huge-score" id="main-player-score">501</div>
        </div>

        <div class="darts-tray">
            <div class="dart-slot" id="dart-1"></div>
            <div class="dart-slot" id="dart-2"></div>
            <div class="dart-slot" id="dart-3"></div>
            <div style="width: 2px; height: 30px; background: rgba(255,255,255,0.2);"></div>
            <div class="turn-sum" id="turn-total">0</div>
        </div>

        <!-- Clavier BullX -->
        <div class="keyboard">
            <div class="mult-row">
                <button class="mult-btn active" data-val="1" onclick="setMult(1)">Simple</button>
                <button class="mult-btn" data-val="2" onclick="setMult(2)">Double</button>
                <button class="mult-btn" data-val="3" onclick="setMult(3)">Triple</button>
            </div>
            
            <div class="numpad">
                <script>for(let i=1; i<=20; i++) document.write(`<button class="num-btn" onclick="addDart(${i})">${i}</button>`);</script>
            </div>
            
            <div class="special-actions">
                <button class="btn-bottom btn-miss" onclick="addDart(0)">Raté (0)</button>
                <button class="btn-bottom btn-bull-outer" onclick="addDart('OB')">Bulle (25)</button>
                <button class="btn-bottom btn-bull-inner" onclick="addDart('IB')">Bulle (50)</button>
            </div>
            
            <!-- Actions Finales -->
            <div class="bottom-actions">
                <button class="btn-undo" id="btn-undo" onclick="undoDart()" disabled>
                    <!-- Icône SVG Retour propre -->
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M3 7v6h6"></path>
                        <path d="M21 17a9 9 0 00-9-9 9 9 0 00-6 2.3L3 13"></path>
                    </svg>
                </button>
                <button class="btn-validate" id="btn-valider" onclick="processTurnEnd()" disabled>VALIDER LE TOUR</button>
            </div>
        </div>
    </div>

    <!-- OVERLAYS D'ANIMATION -->
    <div id="party-overlay">
        <div class="party-text" id="party-message">TEXT</div>
        <div class="party-points" id="party-number">0</div>
    </div>

    <!-- ÉCRAN DE VICTOIRE -->
    <div id="victory-screen">
        <div class="crown">👑</div>
        <div class="win-title">LE CHAMPION EST</div>
        <div class="win-name" id="winner-name">BORIS</div>
        <button class="btn-restart" onclick="closeVictoryAndSetup()">NOUVELLE PARTIE</button>
    </div>

</div>

<script>
    // --- DONNÉES GLOBALES ---
    let app = {
        players: [{ id: 1, name: "Boris", score: 501 }, { id: 2, name: "Adversaire", score: 501 }],
        startingScore: 501, currentIndex: 0, mult: 1, turnDarts: [], turnLabels: [], audioOn: false
    };

    // --- BANQUE DE PHRASES ---
    const phrases = {
        trash: {
            visuel: ["CATASTROPHE", "ÉCLATÉ", "ZÉRO POINTÉ", "AÏE AÏE AÏE", "TU VISES OÙ ?"],
            vocal: ["Sérieusement {nom} ? {score} points ? Va te coucher.", "C'est honteux {nom}. Ferme les yeux ça sera mieux.", "Et {nom} frappe fort avec {score} points. Pitoyable."]
        },
        low: {
            visuel: ["MOUAIS...", "PEUT MIEUX FAIRE", "BOF BOF", "PETIT BRAS"],
            vocal: ["{nom}, {score} points. Tu t'échauffes ou quoi ?", "Seulement {score} pour {nom}. C'est pas terrible."]
        },
        mid: {
            visuel: ["PAS MAL", "PROPRE", "SOLIDE", "C'EST OK"],
            vocal: ["Ok {nom}, {score} points. C'est du travail propre.", "Pas mal du tout {nom}."]
        },
        high: {
            visuel: ["ÉNORME !", "MACHINE !", "MAGNIFIQUE", "QUEL TALENT"],
            vocal: ["Ouh là là ! {nom} lâche un {score} ! Quel monstre !", "Incroyable {nom} ! La machine est lancée !"]
        },
        god: {
            visuel: ["180 !!!", "PERFECT !!", "GOD MODE"],
            vocal: ["One hundred and eighty !!! {nom} est le roi du monde !", "Exceptionnel ! 180 pour {nom} !"]
        },
        bust: {
            visuel: ["BUST !!", "TROP FORT...", "DOMMAGE"],
            vocal: ["Et c'est un Bust pour {nom} ! Faut apprendre à compter !", "Dommage {nom}, tu as explosé le compteur."]
        },
        win: {
            vocal: ["Terminé ! {nom} remporte la partie ! Applaudissements !", "Et c'est la victoire absolue pour {nom} !"]
        }
    };

    // --- SETUP ---
    function renderPlayers() {
        const box = document.getElementById('player-list');
        box.innerHTML = '';
        app.players.forEach((p, i) => {
            box.innerHTML += `
                <div class="player-item">
                    <span style="color:#64748b; font-weight:bold; margin-right:10px;">${i+1}.</span>
                    <input type="text" value="${p.name}" onchange="app.players[${i}].name = this.value">
                    ${app.players.length > 1 ? `<button class="btn-icon" onclick="app.players.splice(${i}, 1); renderPlayers()">🗑️</button>` : ''}
                </div>`;
        });
    }

    function addPlayer() {
        if(app.players.length >= 6) return;
        app.players.push({ id: Date.now(), name: `Joueur ${app.players.length + 1}`, score: app.startingScore });
        renderPlayers();
    }

    function setScore(val) {
        app.startingScore = val;
        document.querySelectorAll('.score-btn').forEach(b => b.classList.remove('selected'));
        event.target.classList.add('selected');
    }

    renderPlayers();

    // --- AUDIO TEXT-TO-SPEECH ---
    function toggleAudio() {
        app.audioOn = !app.audioOn;
        const btn = document.getElementById('btn-audio');
        btn.innerText = app.audioOn ? '🔊' : '🔇';
        btn.classList.toggle('on', app.audioOn);
        if(app.audioOn) speakText("Bull X activé !");
    }

    function speakText(text) {
        if(!app.audioOn || !('speechSynthesis' in window)) return;
        window.speechSynthesis.cancel(); 
        const utterance = new SpeechSynthesisUtterance(text);
        utterance.lang = 'fr-FR';
        utterance.rate = 1.1; 
        window.speechSynthesis.speak(utterance);
    }

    function getRandomPhrase(array, name, score) {
        const randomIndex = Math.floor(Math.random() * array.length);
        let phrase = array[randomIndex];
        return phrase.replace('{nom}', name).replace('{score}', score);
    }

    // --- GAME LOGIC ---
    function startGame() {
        app.players.forEach(p => p.score = app.startingScore);
        app.currentIndex = 0;
        resetTurn(); updateUI();
        document.getElementById('setup-view').classList.remove('active');
        document.getElementById('game-view').classList.add('active');
    }

    function goBack() {
        document.getElementById('game-view').classList.remove('active');
        document.getElementById('setup-view').classList.add('active');
    }

    function updateUI() {
        const p = app.players[app.currentIndex];
        document.getElementById('main-player-name').innerText = p.name;
        document.getElementById('main-player-score').innerText = p.score;

        const dash = document.getElementById('mini-dashboard');
        dash.innerHTML = '';
        app.players.forEach((player, i) => {
            dash.innerHTML += `
                <div class="dash-card ${i === app.currentIndex ? 'active' : ''}">
                    <div class="dash-name">${player.name}</div>
                    <div class="dash-score">${player.score}</div>
                </div>`;
        });
    }

    function setMult(val) {
        app.mult = val;
        document.querySelectorAll('.mult-btn').forEach(b => b.classList.remove('active'));
        document.querySelector(`.mult-btn[data-val="${val}"]`).classList.add('active');
    }

    function addDart(base) {
        if(app.turnDarts.length >= 3) return;
        
        let pts = 0;
        let lbl = "";

        if (base === 'OB') {
            pts = 25; lbl = "25";
        } else if (base === 'IB') {
            pts = 50; lbl = "50";
        } else if (base === 0) {
            pts = 0; lbl = "✖";
        } else {
            let m = app.mult;
            pts = base * m;
            lbl = (m===3 ? "T"+base : (m===2 ? "D"+base : base));
        }

        app.turnDarts.push(pts); 
        app.turnLabels.push(lbl);
        
        setMult(1);
        renderDarts();
    }

    function undoDart() { 
        app.turnDarts.pop(); 
        app.turnLabels.pop(); 
        renderDarts(); 
    }

    function renderDarts() {
        let sum = 0;
        for(let i=1; i<=3; i++) {
            const slot = document.getElementById(`dart-${i}`);
            if(i <= app.turnDarts.length) {
                slot.innerText = app.turnLabels[i-1];
                slot.classList.add('filled');
                sum += app.turnDarts[i-1];
            } else {
                slot.innerText = ""; slot.classList.remove('filled');
            }
        }
        document.getElementById('turn-total').innerText = sum;
        
        // Gérer l'activation des boutons Valider et Undo
        const hasDarts = app.turnDarts.length > 0;
        document.getElementById('btn-valider').disabled = !hasDarts;
        document.getElementById('btn-undo').disabled = !hasDarts;
    }

    // --- GESTION FIN DE TOUR ET ANIMATIONS PARTY ---
    function processTurnEnd() {
        let p = app.players[app.currentIndex];
        let sum = app.turnDarts.reduce((a, b) => a + b, 0);
        let newScore = p.score - sum;

        if (newScore < 0 || newScore === 1) {
            triggerAnimation('bust', p.name, sum);
            setTimeout(() => { nextPlayer(); }, 3500);
        } 
        else if (newScore === 0) {
            p.score = 0;
            updateUI();
            triggerWinScreen(p.name);
        } 
        else {
            p.score = newScore;
            
            let cat = 'trash';
            if (sum === 180) cat = 'god';
            else if (sum >= 100) cat = 'high';
            else if (sum >= 60) cat = 'mid';
            else if (sum >= 20) cat = 'low';

            triggerAnimation(cat, p.name, sum);
            setTimeout(() => { nextPlayer(); }, 3500);
        }
    }

    function triggerAnimation(category, name, score) {
        const overlay = document.getElementById('party-overlay');
        const textEl = document.getElementById('party-message');
        const numEl = document.getElementById('party-number');
        
        const textVisuel = getRandomPhrase(phrases[category].visuel, name, score);
        const textVocal = getRandomPhrase(phrases[category].vocal, name, score);

        textEl.innerText = textVisuel;
        numEl.innerText = category === 'bust' ? 'BUST' : score;
        overlay.className = `show theme-${category}`;
        
        speakText(textVocal);

        setTimeout(() => { overlay.className = ''; }, 3000);
    }

    function triggerWinScreen(winnerName) {
        const vicScreen = document.getElementById('victory-screen');
        document.getElementById('winner-name').innerText = winnerName;
        vicScreen.classList.add('show');
        const winVocal = getRandomPhrase(phrases.win.vocal, winnerName, 0);
        speakText(winVocal);
    }

    function closeVictoryAndSetup() {
        document.getElementById('victory-screen').classList.remove('show');
        goBack(); 
    }

    function nextPlayer() {
        app.currentIndex = (app.currentIndex + 1) % app.players.length;
        resetTurn(); updateUI();
    }

    function resetTurn() {
        app.turnDarts = []; app.turnLabels = []; setMult(1); renderDarts();
    }

</script>

</body>
</html>
